# Logging
LOG_LEVEL=INFO

# 従業員情報 SQLite DB のパス（省略時は data/employees.db）
# DB_PATH=data/employees.db

# HTTP server for SSE transport
HTTP_HOST=0.0.0.0
HTTP_PORT=38117

# DNS リバインディング保護で許可するホスト（カンマ区切り、ポートは ":*" 指定可）。
# 未設定（空）の場合は保護を無効化し、任意のホストからの SSE 接続を許可する。
# LAN 内の特定サーバーのみ許可したい場合に設定する。
# ALLOWED_HOSTS=192.168.3.68:*,localhost:*,127.0.0.1:*
# ALLOWED_ORIGINS=http://192.168.3.68:*,http://localhost:*
